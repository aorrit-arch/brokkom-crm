<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --co: #0A2D56; --mi: #6FB7AE; --ar: #F7F3EF;
  --gr: #2B2F33; --gr2: #5a6370; --ar2: #ede8e2;
}
html { scroll-behavior: smooth; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  color: var(--gr); background: white; line-height: 1.6; font-size: 15px;
}

/* TOP NAV - igual que l'existent */
.top-nav {
  background: var(--co); padding: 10px 20px;
  display: flex; gap: 20px; align-items: center;
  font-size: 13px;
}
.top-nav a { color: rgba(255,255,255,.6); text-decoration: none; }
.top-nav a:hover { color: white; }

/* LAYOUT */
.layout { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 40px); }

/* SIDEBAR */
.sidebar {
  background: var(--co); padding: 20px;
  display: flex; flex-direction: column; gap: 4px;
}
.sidebar-logo {
  display: flex; align-items: center; gap: 8px;
  text-decoration: none; margin-bottom: 20px; padding-bottom: 16px;
  border-bottom: 1px solid rgba(255,255,255,.15);
}
.sidebar-logo img { height: 22px; }
.sidebar-logo span {
  color: white; font-size: 14px; font-weight: 700; letter-spacing: 2px;
}
.sidebar-section {
  font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: rgba(255,255,255,.35);
  margin: 14px 0 6px; padding-top: 10px;
  border-top: 1px solid rgba(255,255,255,.1);
}
.sidebar-section:first-of-type { margin-top: 0; border-top: none; }
.sidebar a {
  display: block; color: rgba(255,255,255,.65); text-decoration: none;
  padding: 5px 8px; border-radius: 5px; font-size: 13px;
  transition: all .15s;
}
.sidebar a:hover, .sidebar a.active { background: rgba(255,255,255,.1); color: white; }
.sidebar-apps { margin-top: auto; padding-top: 16px; border-top: 1px solid rgba(255,255,255,.15); }
.sidebar-apps a {
  color: var(--mi); font-size: 12px; font-weight: 600;
}

/* CONTINGUT */
.content { padding: 40px 48px; max-width: 760px; }
.breadcrumb {
  font-size: 11px; font-weight: 600; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--gr2); margin-bottom: 28px;
}
.breadcrumb a { color: var(--gr2); text-decoration: none; }
.breadcrumb span { color: var(--mi); }

h1 {
  font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2;
  color: var(--co); margin-bottom: 10px;
}
.page-sub {
  font-size: 15px; color: var(--gr2); line-height: 1.65;
  max-width: 560px; margin-bottom: 36px;
}

/* SITUACIÓ CARDS - estil del web existent */
.situacio {
  border-bottom: 1px solid var(--ar2); padding: 22px 0;
}
.situacio:last-of-type { border-bottom: none; }
.sit-title {
  font-size: 16px; font-weight: 600; color: var(--co); margin-bottom: 5px;
}
.sit-desc { font-size: 14px; color: var(--gr2); margin-bottom: 10px; }
.sit-tags { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
.sit-tag {
  font-size: 12px; color: var(--mi); text-decoration: none;
  font-weight: 500;
}
.sit-tag:hover { text-decoration: underline; }
.sit-tag-sep { color: var(--ar2); font-size: 11px; }

/* LANDING LINK - el nou, discret */
.landing-link {
  display: inline-block; font-size: 12px; font-weight: 600;
  color: var(--co); text-decoration: none;
  border: 1px solid var(--ar2); border-radius: 4px;
  padding: 4px 10px; margin-top: 8px;
  transition: all .15s; background: var(--ar);
}
.landing-link:hover { border-color: var(--mi); color: var(--mi); background: white; }
.landing-link::after { content: ' →'; }

/* CTA */
.cta-box {
  background: var(--ar); border-radius: 10px; padding: 24px;
  margin-top: 36px; border: 1px solid var(--ar2);
}
.cta-box p { font-size: 14px; color: var(--gr2); margin-bottom: 14px; }
.cta-box strong { color: var(--co); }
.cta-btn {
  display: inline-block; font-size: 12px; font-weight: 700;
  letter-spacing: .5px; text-transform: uppercase;
  padding: 10px 20px; background: var(--co); color: white;
  text-decoration: none; border-radius: 6px; transition: background .15s;
}
.cta-btn:hover { background: #0d3a6b; }

/* FOOTER */
.page-footer {
  font-size: 12px; color: var(--gr2); margin-top: 40px; padding-top: 20px;
  border-top: 1px solid var(--ar2);
}

/* RESPONSIVE */
@media (max-width: 680px) {
  .layout { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .content { padding: 24px 18px; }
}
</style>
